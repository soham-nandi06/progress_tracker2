rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net: Default Deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable, hardened primitive helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity validation blueprints to prevent shadow-field injection or data poisoning
    function isValidPlanDay(data) {
      return data.keys().hasAll(['id', 'dayNumber', 'completed']) 
        && data.id is string 
        && data.id.size() <= 128
        && data.dayNumber is int
        && data.dayNumber >= 1
        && data.dayNumber <= 100
        && data.completed is bool
        && (data.block1_DSA_Concept == null || (data.block1_DSA_Concept is string && data.block1_DSA_Concept.size() <= 1000))
        && (data.block1_completed == null || data.block1_completed is bool)
        && (data.block2_DSA_Problems == null || (data.block2_DSA_Problems is string && data.block2_DSA_Problems.size() <= 1000))
        && (data.block2_completed == null || data.block2_completed is bool)
        && (data.block3_CF_Upsolve == null || (data.block3_CF_Upsolve is string && data.block3_CF_Upsolve.size() <= 1000))
        && (data.block3_completed == null || data.block3_completed is bool)
        && (data.block4_ML_Theory == null || (data.block4_ML_Theory is string && data.block4_ML_Theory.size() <= 1000))
        && (data.block4_completed == null || data.block4_completed is bool)
        && (data.block5_ML_Project == null || (data.block5_ML_Project is string && data.block5_ML_Project.size() <= 1000))
        && (data.block5_completed == null || data.block5_completed is bool)
        && (data.notes == null || (data.notes is string && data.notes.size() <= 5000))
        && (data.problemsList == null || (data.problemsList is string && data.problemsList.size() <= 5000))
        && (data.projectsList == null || (data.projectsList is string && data.projectsList.size() <= 5000))
        && (data.resources == null || (data.resources is string && data.resources.size() <= 5000))
        && (data.updatedAt == null || (data.updatedAt is string && data.updatedAt.size() <= 128))
        && (data.isBacklog == null || data.isBacklog is bool);
    }

    function isValidStudySession(data) {
      return data.keys().hasAll(['id', 'date', 'blockType', 'durationMinutes'])
        && data.id is string
        && data.id.size() <= 128
        && data.date is string
        && data.date.size() == 10
        && data.blockType is string
        && data.blockType.size() <= 128
        && data.durationMinutes is int
        && data.durationMinutes >= 0
        && data.durationMinutes <= 1440
        && (data.notes == null || (data.notes is string && data.notes.size() <= 5000))
        && (data.createdAt == null || (data.createdAt is string && data.createdAt.size() <= 128))
        && (data.source == null || (data.source is string && data.source.size() <= 128));
    }

    function isValidUserSetting(data) {
      return data.keys().hasAll(['userId'])
        && data.userId is string
        && data.userId.size() <= 128
        && (data.codeforcesHandle == null || (data.codeforcesHandle is string && data.codeforcesHandle.size() <= 128))
        && (data.leetcodeHandle == null || (data.leetcodeHandle is string && data.leetcodeHandle.size() <= 128))
        && (data.startDate == null || (data.startDate is string && data.startDate.size() <= 128))
        && (data.lastSyncedStats == null || (data.lastSyncedStats is string && data.lastSyncedStats.size() <= 10000))
        && (data.vsCodeSyncActive == null || data.vsCodeSyncActive is bool);
    }

    // Rules for individual collections matching the blueprint
    
    // 1. Plan Days Collection
    match /users/{userId}/plan_days/{dayId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(dayId) && isValidPlanDay(request.resource.data);
      allow update: if isOwner(userId) && isValidPlanDay(request.resource.data);
      allow delete: if isOwner(userId);
    }

    // 2. Study Sessions Collection
    match /users/{userId}/study_sessions/{sessionId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(sessionId) && isValidStudySession(request.resource.data);
      allow update: if isOwner(userId) && isValidStudySession(request.resource.data);
      allow delete: if isOwner(userId);
    }

    // 3. User Settings Collection
    match /users/{userId}/settings/{settingId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(settingId) && isValidUserSetting(request.resource.data);
      allow update: if isOwner(userId) && isValidUserSetting(request.resource.data);
      allow delete: if isOwner(userId);
    }
  }
}
