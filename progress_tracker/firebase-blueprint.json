{
  "entities": {
    "plan_day": {
      "title": "Study Plan Day",
      "description": "Represents one day of the 30-day master execution plan.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "dayNumber": { "type": "integer" },
        "block1_DSA_Concept": { "type": "string" },
        "block1_completed": { "type": "boolean" },
        "block2_DSA_Problems": { "type": "string" },
        "block2_completed": { "type": "boolean" },
        "block3_CF_Upsolve": { "type": "string" },
        "block3_completed": { "type": "boolean" },
        "block4_ML_Theory": { "type": "string" },
        "block4_completed": { "type": "boolean" },
        "block5_ML_Project": { "type": "string" },
        "block5_completed": { "type": "boolean" },
        "notes": { "type": "string" },
        "isBacklog": { "type": "boolean" },
        "completed": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "dayNumber", "completed"]
    },
    "study_session": {
      "title": "Study Session Log",
      "description": "Represents a single logged study session for visualization and analysis.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "blockType": { "type": "string" },
        "durationMinutes": { "type": "integer" },
        "notes": { "type": "string" },
        "source": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "date", "blockType", "durationMinutes"]
    },
    "user_setting": {
      "title": "User Configurations",
      "description": "Config for Codeforces, LeetCode, VS Code simulation, and overall goals.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "codeforcesHandle": { "type": "string" },
        "leetcodeHandle": { "type": "string" },
        "vsCodeSyncActive": { "type": "boolean" },
        "lastSyncedStats": { "type": "string" }
      },
      "required": ["userId"]
    }
  },
  "firestore": {
    "users/{userId}/plan_days/{dayId}": {
      "schema": "plan_day",
      "description": "Customized 30-day study plan per user."
    },
    "users/{userId}/study_sessions/{sessionId}": {
      "schema": "study_session",
      "description": "Log of study sessions for historical charts."
    },
    "users/{userId}/settings/config": {
      "schema": "user_setting",
      "description": "User specific accounts and settings."
    }
  }
}
